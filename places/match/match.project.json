{
  "name": "AlienInvasion",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$className": "Folder",
        "Config":         { "$path": "src/shared/Config.luau" },
        "Configs":        { "$path": "src/shared/Configs" },
        "RemoteNames":    { "$path": "src/shared/RemoteNames.luau" },
        "Framework":      { "$path": "../../src/shared/Framework.luau" },
        "Logger":         { "$path": "../../src/shared/Logger.luau" },
        "RenderScheduler": { "$path": "src/shared/RenderScheduler.luau" },
        "ProfileService": { "$path": "../../src/shared/ProfileService.luau" },
        "vide":           { "$path": "../../src/shared/vide" },
        "CombatConfig":   { "$path": "../../src/shared/configs/CombatConfig.luau" }
      },
      "Packages": {
        "$className": "Folder",
        "vide":         { "$path": "../../Packages/_Index/centau_vide@0.4.0/vide/src" },
        "ProfileStore": { "$path": "../../Packages/_Index/vyon_profilestore@1.0.3/profilestore" }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.423,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}